# Tidy Tails v2 — local environment template.
# Copy to `.env.local` (gitignored) and fill in the values below.

# Live Supabase project — REQUIRED.
# As of Ship 2.2a the app uses real Supabase Auth, so these are needed on every
# request — not just for the optional live-data path. Project ref
# pgkwovokciaqnbhpttba. The anon key is the public client key; it is safe in the
# browser with RLS on. It is NOT the service_role key — never put service_role
# here. Do not commit a filled-in .env.local.
NEXT_PUBLIC_SUPABASE_URL=https://pgkwovokciaqnbhpttba.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only key used by public webhooks that cannot carry Sam's browser
# session, including Twilio inbound SMS. Never expose this in NEXT_PUBLIC_ envs.
TIDYTAILS_SUPABASE_SERVICE_ROLE_KEY=

# Data source. Leave unset (or anything other than "on") for anonymized
# fixtures. Set to "on" to read from the live Supabase project — SELECT only.
NEXT_PUBLIC_USE_LIVE_DATA=

# Operator allowlist — server-only, PRIVATE.
# The app rejects any signed-in Supabase Auth user whose email is not listed
# here. Comma-separate multiple operators if a backup account is deliberately
# approved. If unset, production code defaults to Sam's account only.
TIDYTAILS_ALLOWED_EMAILS=sammclennan143@gmail.com

# Post-cutover write kill-switches — server-only, OFF by default.
# Each of v2's four write surfaces is gated by a PRIVATE flag. These are NOT
# prefixed NEXT_PUBLIC_ on purpose: the value must never reach the browser
# bundle. A surface persists data only when its flag is the EXACT string "on" —
# unset, empty, "false", "off", "true", "ON", or anything else keeps it OFF.
# Leave ALL of these unset until the Ship 2.2b RLS cutover is green AND the
# surface's flip is explicitly approved — see
# ../_reports/2026-05-18-ship-2.2b-write-flip-plan.md. Enabling or disabling a
# surface is a Vercel env change + redeploy, never a code edit.
TIDYTAILS_ENABLE_ADD_APPOINTMENT_WRITE=
TIDYTAILS_ENABLE_LOG_GROOM_WRITE=
TIDYTAILS_ENABLE_REMINDER_SEND=
TIDYTAILS_ENABLE_ADD_HOUSEHOLD_WRITE=
TIDYTAILS_ENABLE_ADD_PET_WRITE=
TIDYTAILS_ENABLE_EDIT_PET_WRITE=
TIDYTAILS_ENABLE_EDIT_CLIENT_WRITE=
TIDYTAILS_ENABLE_EDIT_APPOINTMENT_WRITE=

# Two-way SMS — server-only.
# Outbound sends can use either ACCOUNT_SID + AUTH_TOKEN or the preferred
# ACCOUNT_SID + API_KEY_SID + API_KEY_SECRET pair. Inbound webhook signature
# validation uses WEBHOOK_SECRET first, then AUTH_TOKEN as a fallback; set
# WEBHOOK_SECRET to the Twilio auth token for the messaging account/number.
TIDYTAILS_TWILIO_ACCOUNT_SID=
TIDYTAILS_TWILIO_AUTH_TOKEN=
TIDYTAILS_TWILIO_API_KEY_SID=
TIDYTAILS_TWILIO_API_KEY_SECRET=
TIDYTAILS_TWILIO_FROM_NUMBER=
TIDYTAILS_TWILIO_WEBHOOK_SECRET=

# Google Calendar sync — server-only.
# Create an OAuth web application in Google Cloud with redirect URI:
# https://tidy-tails-v2.vercel.app/settings/google/callback
# TOKEN_SECRET must be 32 random bytes encoded as base64.
TIDYTAILS_ENABLE_GOOGLE_CALENDAR_SYNC=
TIDYTAILS_GOOGLE_CLIENT_ID=
# Optional: modern Google OAuth clients can use PKCE without a client secret.
TIDYTAILS_GOOGLE_CLIENT_SECRET=
TIDYTAILS_GOOGLE_TOKEN_SECRET=
TIDYTAILS_GOOGLE_REDIRECT_URI=https://tidy-tails-v2.vercel.app/settings/google/callback
TIDYTAILS_APP_URL=https://tidy-tails-v2.vercel.app
